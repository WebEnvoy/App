{
  "name": "@webenvoy/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "build": "npm run typecheck && npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "start": "electron dist-electron/main.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
